  <weightValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.010091954842209816</weightValue>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#fw_cluster_0_semantic_anomaly">
  <rdf:type rdf:resource="#FeatureWeight"/>
